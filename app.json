{
  "expo": {
    "name": "EDURA Test",
    "slug": "edura-test",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "eduratest",
    "primaryColor": "#6C63FF",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edura.test",
      "requiresFullScreen": true
    },
    "android": {
      "package": "com.edura.test",
      "versionCode": 1,
      "permissions": [
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-updates",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": false,
            "enableShrinkResourcesInReleaseBuilds": false,
            "extraMavenRepos": []
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be00d321-153d-48f4-9647-e555a4bb28a9"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/be00d321-153d-48f4-9647-e555a4bb28a9"
    }
  }
}
